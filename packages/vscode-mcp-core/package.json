{
    "name": "@vscode-mcp/vscode-mcp-core",
    "version": "4.8.0",
    "type": "module",
    "description": "Shared tool definitions and formatters for VSCode MCP server and CLI",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "clean": "rm -rf dist",
        "typecheck": "tsgo --noEmit",
        "prepublishOnly": "pnpm run clean && pnpm run build"
    },
    "keywords": [
        "vscode",
        "mcp",
        "core"
    ],
    "author": {
        "name": "YuTengjing",
        "email": "ytj2713151713@gmail.com"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@vscode-mcp/vscode-mcp-ipc": "workspace:*",
        "zod": "^4.3.6"
    }
}
