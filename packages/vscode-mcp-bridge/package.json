{
    "name": "vscode-mcp-bridge",
    "displayName": "Vscode Mcp Bridge",
    "version": "4.7.3",
    "description": "A vscode extension which connect vscode and mcp",
    "publisher": "YuTengjing",
    "private": true,
    "preview": true,
    "author": {
        "name": "YuTengjing",
        "email": "ytj2713151713@gmail.com",
        "url": "https://github.com/tjx666"
    },
    "license": "MIT",
    "homepage": "https://github.com/tjx666/vscode-mcp-bridge/blob/master/README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/tjx666/vscode-mcp-bridge"
    },
    "bugs": {
        "url": "https://github.com/tjx666/vscode-mcp-bridge/issues",
        "email": "ytj2713151713@gmail.com"
    },
    "keywords": [
        "cursor",
        "windsurf",
        "mcp",
        "lsp",
        "command"
    ],
    "categories": [
        "Other"
    ],
    "main": "./out/src/extension.js",
    "icon": "assets/logo.png",
    "engines": {
        "vscode": "^1.102.0"
    },
    "badges": [
        {
            "url": "https://img.shields.io/badge/PRs-welcome-brightgreen.svg",
            "description": "PRs Welcome",
            "href": "https://github.com/tjx666/vscode-mcp-bridge/fork"
        }
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "capabilities": {
        "untrustedWorkspaces": {
            "supported": "limited",
            "description": "In untrusted workspaces, terminal launcher entries from workspace settings are ignored to prevent arbitrary command execution.",
            "restrictedConfigurations": [
                "vscode-mcp-bridge.terminalLauncher.items"
            ]
        }
    },
    "contributes": {
        "configuration": {
            "type": "object",
            "title": "VSCode MCP Bridge",
            "properties": {
                "vscode-mcp-bridge.enableLog": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable logging for VSCode MCP Bridge operations"
                },
                "vscode-mcp-bridge.terminalLauncher.items": {
                    "type": "array",
                    "default": [],
                    "restricted": true,
                    "markdownDescription": "Quick-launch entries shown as icon buttons on the terminal toolbar. Pick an `icon` from the bundled pool; each icon can only be bound to one entry (first wins on duplicates). Ignored in untrusted workspaces.",
                    "items": {
                        "type": "object",
                        "required": ["label", "icon"],
                        "additionalProperties": false,
                        "properties": {
                            "label": {
                                "type": "string",
                                "description": "Display name for the terminal tab and button tooltip."
                            },
                            "icon": {
                                "type": "string",
                                "enum": ["claude", "codex", "gemini"],
                                "description": "Which bundled SVG to show on the terminal toolbar."
                            },
                            "command": {
                                "type": "string",
                                "default": "",
                                "description": "Shell command sent to the terminal after creation. Empty string opens a plain shell."
                            },
                            "color": {
                                "type": "string",
                                "description": "Theme color id for the terminal tab icon, e.g. \"terminal.ansiBlue\"."
                            }
                        }
                    }
                }
            }
        },
        "commands": [
            {
                "command": "vscode-mcp-bridge.sleep",
                "title": "Sleep",
                "category": "VSCode MCP Bridge"
            },
            {
                "command": "vscode-mcp-bridge.copyOpenedFilesPath",
                "title": "Copy Opened Files Path",
                "category": "VSCode MCP Bridge"
            },
            {
                "command": "vscode-mcp-bridge.copyCurrentSelectionReference",
                "title": "Copy Current Selection Reference",
                "category": "VSCode MCP Bridge"
            },
            {
                "command": "vscode-mcp-bridge.terminalLauncher.icon.claude",
                "title": "Terminal Launcher: Claude",
                "category": "VSCode MCP Bridge",
                "icon": "resources/launcher-icons/claude.svg"
            },
            {
                "command": "vscode-mcp-bridge.terminalLauncher.icon.codex",
                "title": "Terminal Launcher: Codex",
                "category": "VSCode MCP Bridge",
                "icon": "resources/launcher-icons/codex.svg"
            },
            {
                "command": "vscode-mcp-bridge.terminalLauncher.icon.gemini",
                "title": "Terminal Launcher: Gemini",
                "category": "VSCode MCP Bridge",
                "icon": "resources/launcher-icons/gemini.svg"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "vscode-mcp-bridge.terminalLauncher.icon.claude",
                    "when": "view == terminal && vscodeMcpBridge.launcher.icon.claude.visible",
                    "group": "navigation@-3"
                },
                {
                    "command": "vscode-mcp-bridge.terminalLauncher.icon.codex",
                    "when": "view == terminal && vscodeMcpBridge.launcher.icon.codex.visible",
                    "group": "navigation@-2"
                },
                {
                    "command": "vscode-mcp-bridge.terminalLauncher.icon.gemini",
                    "when": "view == terminal && vscodeMcpBridge.launcher.icon.gemini.visible",
                    "group": "navigation@-1"
                }
            ]
        },
        "keybindings": [
            {
                "key": "alt+cmd+o",
                "command": "vscode-mcp-bridge.copyOpenedFilesPath",
                "args": {
                    "isSendToActiveTerminal": true,
                    "includeAtSymbol": true,
                    "addQuotes": false,
                    "focusTerminal": true
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "pnpm esbuild:base --minify",
        "clean": "npx rimraf -rf ./out",
        "esbuild:base": "tsx scripts/esbuild.ts",
        "esbuild:watch": "pnpm esbuild:base --sourcemap --watch",
        "esbuild:analyze": "pnpm esbuild:base --minify --metafile --analyze && esbuild-visualizer --metadata ./meta.json --open",
        "typecheck": "tsc --noEmit -p src/tsconfig.json",
        "build": "pnpm esbuild:base",
        "compile:test": "pnpm clean && tsc -b ./test/tsconfig.json",
        "lint": "eslint src --ext ts",
        "test": "pnpm compile:test && node ./out/test/runTests.js",
        "package": "vsce package --no-dependencies",
        "release": "tsx scripts/release.ts",
        "publish:vs-marketplace": "vsce publish --no-dependencies",
        "publish:open-vsx": "ovsx publish --no-dependencies"
    },
    "dependencies": {
        "@vscode-mcp/vscode-mcp-ipc": "workspace:*",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/glob": "^9.0.0",
        "@types/mocha": "^10.0.10",
        "@types/vscode": "1.102.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "~0.27.3",
        "esbuild-visualizer": "^0.7.0",
        "glob": "^13.0.6",
        "mocha": "^11.7.5",
        "ovsx": "^0.10.9",
        "rimraf": "^6.1.3"
    }
}
