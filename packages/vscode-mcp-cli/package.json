{
    "name": "@vscode-mcp/vscode-mcp-cli",
    "version": "4.8.3",
    "type": "module",
    "description": "CLI that calls VSCode MCP Bridge capabilities directly (no MCP client needed)",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "vscode-cli": "dist/index.js"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "clean": "rm -rf dist",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "typecheck": "tsgo --noEmit",
        "prepublishOnly": "pnpm run clean && pnpm run build"
    },
    "keywords": [
        "vscode",
        "cli",
        "agent",
        "mcp"
    ],
    "author": {
        "name": "YuTengjing",
        "email": "ytj2713151713@gmail.com"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@vscode-mcp/vscode-mcp-core": "workspace:*",
        "@vscode-mcp/vscode-mcp-ipc": "workspace:*",
        "commander": "^14.0.1",
        "zod": "^4.3.6"
    }
}
